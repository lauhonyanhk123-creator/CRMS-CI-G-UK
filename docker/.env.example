# =============================================================================
# CRMS CI G UK — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
SPRING_PROFILES=prod
TZ=Europe/London

# ---------------------------------------------------------------------------
# PostgreSQL — CHANGE THESE IN PRODUCTION
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=ChangeMe_UseAStrongRandomPassword_AtLeast32Chars!

# ---------------------------------------------------------------------------
# Application Secrets — CHANGE THESE IN PRODUCTION
# ---------------------------------------------------------------------------
# Generate a JWT secret with: openssl rand -base64 32 | tr -d '\n'
# The value below is a placeholder — systems with this value will not start
# in production environments.
JWT_SECRET=Y3Jtc2MtanV3dC1zZWNyZXQta2V5LXBsYWNlaG9sZGVyLW1pbmltdW0tMjU2LWJpdHMtcmVxdWlyZWQtZm9yLWhzMjU2

# Generate an app secret with: openssl rand -hex 32
APP_SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ---------------------------------------------------------------------------
# MinIO Object Storage — CHANGE THESE IN PRODUCTION
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=crms_minio_admin
MINIO_ROOT_PASSWORD=ChangeMe_UseAStrongRandomPassword_AtLeast16Chars!

# ---------------------------------------------------------------------------
# CORS — Add your frontend URL(s) here
# ---------------------------------------------------------------------------
# For a single server: CORS_ALLOWED_ORIGINS=http://your-server.local
# For multiple origins: CORS_ALLOWED_ORIGINS=http://192.168.1.10,http://crms.yourcompany.co.uk
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------------------------------------------------------------------------
# HMRC MTD CIS Integration
# ---------------------------------------------------------------------------
# Set HMRC_DEMO_MODE=false and supply real credentials for live submissions.
# After deploying with live credentials, an admin completes the OAuth2 flow:
#   GET /api/v1/hmrc/oauth/begin  (then follow the returned URL)
HMRC_DEMO_MODE=true
HMRC_CLIENT_ID=
HMRC_CLIENT_SECRET=
HMRC_CONTRACTOR_UTR=
HMRC_REDIRECT_URI=https://your-domain.com/api/v1/hmrc/oauth/callback
HMRC_BASE_URL=https://test-api.service.hmrc.gov.uk

# ---------------------------------------------------------------------------
# SMTP / Email (optional — for alerts and notifications)
# ---------------------------------------------------------------------------
# MAIL_HOST=smtp.yourprovider.com
# MAIL_PORT=587
# MAIL_USERNAME=alerts@yourcompany.co.uk
# MAIL_PASSWORD=your_smtp_password

# ---------------------------------------------------------------------------
# Redis — token blacklist and session cache (included in docker-compose)
# ---------------------------------------------------------------------------
REDIS_PASSWORD=ChangeMe_UseAStrongRandomPassword_AtLeast16Chars!

# ---------------------------------------------------------------------------
# Kafka (optional — for async event processing)
# ---------------------------------------------------------------------------
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ---------------------------------------------------------------------------
# HTTP/HTTPS Ports
# ---------------------------------------------------------------------------
HTTP_PORT=80
HTTPS_PORT=443

# ---------------------------------------------------------------------------
# Data directory (bind mounts)
# ---------------------------------------------------------------------------
DATA_DIR=./data

# ---------------------------------------------------------------------------
# Backup retention (days)
# ---------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=30
