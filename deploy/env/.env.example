# CRMS CI G UK - Environment Template
# Copy this file to .env and fill in the values

# =============================================================================
# REGISTRY CONFIGURATION
# =============================================================================
REGISTRY=ghcr.io/crms-ci-g-uk
VERSION=latest

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
POSTGRES_PASSWORD=change_me_in_production_use_strong_password

# =============================================================================
# MINIO (S3-compatible storage) CONFIGURATION
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_use_strong_password_min_8_chars

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Application secret key (32+ characters)
APP_SECRET_KEY=change_this_to_a_secure_random_string_at_least_32_chars

# JWT signing secret (64+ characters recommended)
JWT_SECRET=change_this_to_a_secure_random_string_for_jwt_signing

# =============================================================================
# HMRC MTD CIS CONFIGURATION
# =============================================================================
# Register your application at https://developer.service.hmrc.gov.uk/
# Required scopes: read:construction-industry-scheme write:construction-industry-scheme
#
# Set HMRC_DEMO_MODE=false to use live HMRC APIs.
# When live mode is enabled, an admin must complete the OAuth2 authorisation flow:
#   1. GET /api/v1/hmrc/oauth/begin  -> follow the returned authorizationUrl
#   2. HMRC redirects to HMRC_REDIRECT_URI with an authorisation code
#   3. The callback endpoint exchanges the code and stores the tokens
#
HMRC_DEMO_MODE=true
HMRC_CLIENT_ID=your_hmrc_client_id
HMRC_CLIENT_SECRET=your_hmrc_client_secret
# The contractor's UTR (10 digits) registered with HMRC CIS
HMRC_CONTRACTOR_UTR=0000000000
# Must match the redirect URI registered in the HMRC Developer Hub
HMRC_REDIRECT_URI=https://your-domain.com/api/v1/hmrc/oauth/callback
# Leave blank to use the sandbox; set to https://api.service.hmrc.gov.uk for production
HMRC_BASE_URL=https://test-api.service.hmrc.gov.uk

# =============================================================================
# OPTIONAL: TLS/SSL CONFIGURATION
# =============================================================================
# For production, place SSL certificates in ./nginx/ssl/
# - fullchain.pem
# - privkey.pem
