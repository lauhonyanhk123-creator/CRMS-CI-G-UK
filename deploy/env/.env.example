# CRMS CI G UK - Environment Template
# Copy this file to .env and fill in the values

# =============================================================================
# REGISTRY CONFIGURATION
# =============================================================================
REGISTRY=ghcr.io/crms-ci-g-uk
VERSION=latest

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
POSTGRES_PASSWORD=change_me_in_production_use_strong_password

# =============================================================================
# MINIO (S3-compatible storage) CONFIGURATION
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_use_strong_password_min_8_chars

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Application secret key (32+ characters)
APP_SECRET_KEY=change_this_to_a_secure_random_string_at_least_32_chars

# JWT signing secret (64+ characters recommended)
JWT_SECRET=change_this_to_a_secure_random_string_for_jwt_signing

# =============================================================================
# HMRC API CONFIGURATION
# =============================================================================
HMRC_API_MODE=production

# =============================================================================
# OPTIONAL: TLS/SSL CONFIGURATION
# =============================================================================
# For production, place SSL certificates in ./nginx/ssl/
# - fullchain.pem
# - privkey.pem
